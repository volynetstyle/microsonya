# Telegram bot token from @BotFather. Required.
TELEGRAM_BOT_TOKEN=

# Local Postgres connection used by Drizzle and the bot when running outside Docker.
# If the password contains special characters, URL-encode them: # -> %23, @ -> %40.
DATABASE_URL=postgresql://microsonya:microsonya@localhost:5432/microsonya

# OpenRouter is the default OpenAI-compatible provider.
# Either OPENROUTER_TOKEN or LLM_API_KEY can be used.
OPENROUTER_TOKEN=
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1

# Use one fixed model, or leave empty and use the fallback list below.
LLM_MODEL=

# Comma-separated fallback models. The gateway tries them in order.
LLM_MODELS=nvidia/nemotron-3-nano-30b-a3b:free,openai/gpt-oss-20b:free,nvidia/nemotron-nano-9b-v2:free,google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,qwen/qwen3-next-80b-a3b-instruct:free

# Comma-separated models temporarily excluded from the fallback list.
LLM_QUARANTINE_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,google/gemma-4-26b-a4b-it:free

# Optional defaults used by Docker Compose's Postgres service.
POSTGRES_DB=microsonya
POSTGRES_USER=microsonya
POSTGRES_PASSWORD=microsonya
POSTGRES_PORT=5432
