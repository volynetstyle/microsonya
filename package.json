{
  "name": "microsonya",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @microsonya/db generate",
    "db:migrate": "pnpm --filter @microsonya/db migrate",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:logs": "docker compose logs -f telegram-bot",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:json": "prettier --write \"**/*.{json,jsonc}\"",
    "format:json:check": "prettier --check \"**/*.{json,jsonc}\"",
    "start": "pnpm bot:start",
    "bot:start": "pnpm --filter @microsonya/telegram-bot start",
    "test": "vitest run"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/node": "^22.15.34",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.22.0",
    "prettier": "^3.8.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
