{
  "name": "microsonya",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm -r build",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:logs": "docker compose logs -f telegram-bot",
    "typecheck": "pnpm -r typecheck",
    "start": "pnpm --filter @microsonya/telegram-bot start",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.15.34",
    "dotenv": "^16.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
