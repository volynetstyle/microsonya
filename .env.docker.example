# Telegram bot token from @BotFather. Required.
TELEGRAM_BOT_TOKEN=

# OpenRouter is the default OpenAI-compatible provider.
# Either OPENROUTER_TOKEN or LLM_API_KEY can be used.
OPENROUTER_TOKEN=
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1

# Leave DATABASE_URL empty to let compose point the bot at the postgres service.
# Set it only when using an external Postgres database.
DATABASE_URL=

# Use one fixed model, or leave empty and use the fallback list in compose.yaml.
LLM_MODEL=
LLM_MODELS=
LLM_QUARANTINE_MODELS=

# Local Postgres container settings.
POSTGRES_DB=microsonya
POSTGRES_USER=microsonya
POSTGRES_PASSWORD=microsonya
POSTGRES_PORT=5432
